{
    "name": "bahricanli/laravel-publisher",
    "version": "1.0.3",
    "description": "Connects your Laravel app to content-manager.tr — publish, update and delete posts via a secure token-based API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bahri Meriç Canlı",
            "homepage": "https://www.bahricanli.tr"
        }
    ],
    "require": {
        "php": ">=5.6.4",
        "illuminate/support": "~5.3|~6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "~5.3|~6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "~5.3|~6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "BahriCanli\\Publisher\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BahriCanli\\Publisher\\PublisherServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
