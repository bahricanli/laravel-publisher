{
    "name": "bahricanli/cm-laravel-publisher",
    "description": "Connects your Laravel app to content-manager.tr — publish, update and delete posts via a secure token-based API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bahri Meriç Canlı",
            "homepage": "https://www.bahricanli.tr"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "BahriCanli\\CmPublisher\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BahriCanli\\CmPublisher\\CmPublisherServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
